<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>LCE_Qt_Launcher_Wizard</class>
 <widget class="QWizard" name="LCE_Qt_Launcher_Wizard">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>500</width>
    <height>360</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>LCE Qt Launcher Setup</string>
  </property>
  <property name="windowIcon">
   <iconset resource="../res.qrc">
    <normaloff>:/assets/jigsaw-ico.png</normaloff>:/assets/jigsaw-ico.png</iconset>
  </property>
  <widget class="QWizardPage" name="wizardPage1">
   <layout class="QVBoxLayout" name="wizardPage1VerticalLayout">
    <item>
     <widget class="QTextBrowser" name="textBrowser">
      <property name="html">
       <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;meta charset=&quot;utf-8&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
hr { height: 1px; border-width: 0; }
li.unchecked::marker { content: &quot;\2610&quot;; }
li.checked::marker { content: &quot;\2612&quot;; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Sans Serif'; font-size:9pt; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:12pt;&quot;&gt;Welcome to &lt;/span&gt;&lt;span style=&quot; font-size:12pt; font-weight:700;&quot;&gt;LCE Qt Launcher&lt;/span&gt;&lt;span style=&quot; font-size:12pt; font-style:italic;&quot;&gt; {channel} {version-number}&lt;/span&gt;&lt;span style=&quot; font-size:12pt;&quot;&gt; !&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;img src=&quot;:/assets/app.ico&quot; /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;This setup wizard will help you setup this launcher for the first launch.&lt;/p&gt;
&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;For more help, these links can useful : &lt;/p&gt;
&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;- &lt;a href=&quot;https://github.com/xgui4/LCE-Qt-Launcher&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#8aadf4;&quot;&gt;Official GitHub , &lt;/span&gt;&lt;/a&gt;&lt;a href=&quot;https://code.nolog.cz/xgui4/lce-qt-launcher&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#8aadf4;&quot;&gt;Official backup/mirror&lt;/span&gt;&lt;/a&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;- &lt;a href=&quot;https://xgui4.github.io/lce-qt-launcher&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#8aadf4;&quot;&gt;Official Site&lt;/span&gt;&lt;/a&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;- &lt;a href=&quot;https:///code.nolog.cz/xgui4/lce-qt-launcher-data&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#8aadf4;&quot;&gt;Official Instance Data Repo&lt;/span&gt;&lt;/a&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
      </property>
     </widget>
    </item>
   </layout>
  </widget>
  <widget class="QWizardPage" name="wizardPage2">
   <layout class="QGridLayout" name="wizardPage2GridLayout">
    <item row="0" column="0">
     <widget class="QLabel" name="instanceDataSourceInputBoxLabel">
      <property name="font">
       <font>
        <bold>true</bold>
       </font>
      </property>
      <property name="text">
       <string>Instance Data Source</string>
      </property>
     </widget>
    </item>
    <item row="1" column="0">
     <widget class="QLineEdit" name="instanceDataSourceInputBox">
      <property name="text">
       <string>https://code.nolog.cz/xgui4/lce-qt-launcher-data</string>
      </property>
     </widget>
    </item>
   </layout>
  </widget>
 </widget>
 <resources>
  <include location="../res.qrc"/>
 </resources>
 <connections/>
</ui>
