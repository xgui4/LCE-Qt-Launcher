# Maintainer: Xgui4
pkgname=lce_qt_launcher
pkgver=nighly-$date
pkgrel=1
pkgdesc=" This is a free/libre MC LCE Launcher written in Python and Qt"
arch=('any')
url="https://github.com/xgui4/lce-qt-launcher"
license=('GPLv3')
depends=('python' 'pyside6' 'python-rich' 'python-requests')
makedepends=(pyside6-tools 'git')
source=("https://github.com/xgui4/lce-qt-launcher.git")
sha256sums=('skip')

version() {  
   date=$(date)
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    install -Dm755 src/* "$pkgdir/usr/bin/*"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 readme.md "$pkgdir/usr/share/doc/$pkgname/readme.md"
    install -Dm644 code-of-conduct.md "$pkgdir/usr/share/doc/$pkgname/code-of-conduct.md"
}