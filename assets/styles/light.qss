* {
    background-color : white;
    color : black; 
}

QLabel:disabled {
    color : gray; 
    opacity : 150;
}

QPushButton {
    color : white;
    border : none;
}

QPushButton:pressed {
    color : white;
    font : bold; 
    border : none;
}

QPushButton:hover { 
    color : white;
    text-decoration : underline;
    border : none;
}

QPushButton:disabled { 
    opacity : 200;
    border : none;
}

QPushButton:disabled { 
    opacity : 150;
    border : 5px;
}

QMainWindow QLabel {
    color : white;
}

QStatusBar {
    color : black;
    background-color : white;
}

QMainWindow QLabel {
    color : black;
}

QMenu::item {
    color: white;
    background-color : black;
}

QMenu::item:selected {
    color: yellow;
    text-decoration: underline;
}

QMenu::item:disabled {
    color: gray;
    opacity : 150;
}

QMenu {
    background-color : white;
}

QMenuBar {
    background-color : white;
}

QMenuBar::item {
    color : black;
    background-color : white;
}

QMenuBar::item:disabled {
    color : gray;
    background-color : white;
}

QGroupBox {
    background-color: transparent;
}